<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet for debug WebSocket mode -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Bluetooth for CXR-S communication -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Camera for screenshots -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Audio: voice recognition is handled on the phone, not the glasses -->

    <!-- Keep display active -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".GlassesApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.GlassesHUD">

        <activity
            android:name=".HudActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.GlassesHUD">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Service to receive data from phone -->
        <service
            android:name=".service.PhoneConnectionService"
            android:exported="false" />
        <!-- R08 ring input bridge -->
        <service
            android:name=".input.JsosRingAccessibilityService"
            android:exported="true"
            android:label="@string/jsos_ring_accessibility_service_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/jsos_ring_accessibility_service" />
        </service>
    </application>

</manifest>
